# Dynamics 365 CRM Integration
D365_TENANT_ID=00000000-0000-0000-0000-000000000000
D365_CLIENT_ID=00000000-0000-0000-0000-000000000000
D365_CLIENT_SECRET=replace_with_client_secret
D365_RESOURCE_URL=https://your-org.crm.dynamics.com/

# Customer
D365_CUSTOMER_ENTITY_SET=accounts
D365_CUSTOMER_MATCH_FIELD=jh_thinkidnbr
D365_CUSTOMER_PRIMARY_ID_FIELD=accountid

# Agency
D365_AGENCY_ENTITY_SET=accounts
D365_AGENCY_MATCH_FIELD=jh_thinkidnbr
D365_AGENCY_PRIMARY_ID_FIELD=accountid

# Payment
D365_PAYMENT_ENTITY_SET=jh_entitlements
D365_PAYMENT_MATCH_FIELD=jh_name
D365_PAYMENT_PRIMARY_ID_FIELD=jh_entitlementid

# Order Item
D365_ORDER_ITEM_ENTITY_SET=jh_entitlementitems
D365_ORDER_ITEM_MATCH_FIELD=jh_name
D365_ORDER_ITEM_PRIMARY_ID_FIELD=jh_entitlementitemid

# Logging
D365_LOG_DIR=logs
# D365_LOG_PATH=logs/crm_push.log

# Batch / Parallel
D365_BATCH_ENABLED=true
D365_BATCH_PARALLEL=true
D365_BATCH_SIZE=50
D365_BATCH_MAX_WORKERS=4
